{
  "name": "storage-helper-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/admin",
    "packages/contracts"
  ],
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "dev-api": "npm --workspace apps/api run start:dev",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev-admin": "npm --workspace apps/admin run dev",
    "dev": "npm run dev-api & npm run dev-admin",
    "dev:admin": "npm --workspace apps/admin run dev",
    "api:prisma:generate": "npm --workspace apps/api run prisma:generate",
    "api:db:push": "npm --workspace apps/api run db:push",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  }
}
